---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StarRating from '../components/StarRating.astro';

const passeio = {
  titulo: "Space Adventure",
  subtitulo: "A experiência oficial da NASA na Serra Gaúcha",
  categoria: "INGRESSOS E ATRAÇÕES",
  preco: 39.90,
  avaliacao: 4.00,
  totalAvaliacoes: 6,
  parcelas: "6x sem juros",
  descricao: "Prepare-se para uma viagem inesquecível ao espaço sem sair da Terra! O Space Adventure é a primeira exposição oficial da NASA no Brasil, reunindo mais de 270 itens originais utilizados em missões espaciais. Localizada em Canela, a atração é imperdível para curiosos, apaixonados por ciência e fãs da exploração espacial de todas as idades.",
  inclusos: [
    "Entrada no Parque Space Adventure",
    "Acesso ao Planetário 4K",
    "Estacionamento gratuito"
  ],
  naoInclusos: [
    "Alimentação e/ou bebidas",
    "Jogos adicionais",
    "Transporte até o parque"
  ],
  duracao: "Dia inteiro",
  horarios: ["10h às 18h (entrada até 17h)"],
  endereco: "Av. Ernani Kroeff Fleck, 960 - Vila Suíça, Canela/RS",
  galeria: [
    "/images/spaceadventure/space01.webp",
    "/images/spaceadventure/space01.webp",
    "/images/spaceadventure/space01.webp"
  ],
  destaques: [
    "Cápsula Lunar da Apollo 11 com interior original",
    "Sala de Comando de Houston (em réplica fiel)",
    "Módulo Lunar em tamanho real",
    "Simuladores imersivos – experimente a decolagem de um foguete",
    "Planetário 4K de última geração",
    "Área dedicada à missão para Marte"
  ],
  tags: ["NASA Oficial", "Exposição Espacial", "Planetário 4K", "Simuladores"]
};

const whatsappMessage = `Olá! Gostaria de mais informações sobre o ${passeio.titulo} - ${passeio.subtitulo}. Valor: R$ ${passeio.preco.toFixed(2).replace('.', ',')} em ${passeio.parcelas}.`;
const whatsappUrl = `https://wa.me/5554993723094?text=${encodeURIComponent(whatsappMessage)}`;
---

<BaseLayout 
  title={`${passeio.titulo} - ${passeio.subtitulo} | Partiu Viagem`}
  description={passeio.descricao}
>
  <Header />
  
  <main class="pt-20 lg:pt-24">
    <!-- Hero Section -->
    <section class="relative h-96 lg:h-[500px] overflow-hidden" style={`background-image: url('${passeio.galeria[0]}'); background-attachment: fixed; background-size: cover; background-position: center; background-repeat: no-repeat;`}>
      <div class="absolute inset-0 bg-black/40"></div>
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="text-center text-white px-4">
          <span class="inline-block px-3 py-1 bg-primary-600 text-white text-sm font-medium rounded-full mb-4">
            {passeio.categoria}
          </span>
          <h1 class="text-4xl lg:text-6xl font-bold mb-4">{passeio.titulo}</h1>
          <p class="text-xl lg:text-2xl text-gray-200">{passeio.subtitulo}</p>
        </div>
      </div>
    </section>

    <div class="container mx-auto px-4 py-12">
      <div class="grid lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <!-- Avaliações e Preço -->
          <div class="flex flex-wrap items-center justify-between mb-8 p-6 bg-gray-50 rounded-xl">
            <div class="flex flex-col mb-4 lg:mb-0">
              <p class="text-gray-700 font-medium mb-1"><strong>Nossos Clientes Recomendam:</strong></p>
              <div class="flex items-center space-x-4">
                <StarRating rating={passeio.avaliacao} />
                <span class="text-gray-600">({passeio.totalAvaliacoes} avaliações)</span>
              </div>
            </div>
            <div class="text-right">
              <div class="text-gray-600 text-sm mb-1">A partir de:</div>
              <div class="text-3xl font-bold text-primary-600">R$ {passeio.preco.toFixed(2).replace('.', ',')}</div>
            </div>
          </div>

          <!-- Descrição -->
          <div class="mb-8">
            <h2 class="text-2xl font-bold mb-4">Sobre esta atração</h2>
            <p class="text-gray-700 leading-relaxed mb-4">{passeio.descricao}</p>
            <p class="text-gray-700 leading-relaxed">Em um espaço de mais de 4 mil m², a exposição conta com a colaboração do Museu e Centro de Educação Espacial Cosmosphere, de Kansas (EUA), trazendo itens originais dos projetos Mercury, Gemini e Apollo.</p>
          </div>

          <!-- Destaques da Experiência -->
          <div class="mb-8">
            <h3 class="text-xl font-bold mb-4">🚀 Destaques da experiência Space Adventure</h3>
            <div class="grid md:grid-cols-2 gap-4">
              {passeio.destaques.map(destaque => (
                <div class="flex items-start space-x-3 p-4 bg-blue-50 rounded-lg">
                  <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-gray-700 text-sm">{destaque}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- O que está incluso -->
          <div class="mb-8">
            <h3 class="text-xl font-bold mb-4">✅ O que está incluso</h3>
            <ul class="space-y-2">
              {passeio.inclusos.map(item => (
                <li class="flex items-center space-x-3">
                  <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-gray-700">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Tags -->
          <div class="mb-8">
            <h3 class="text-xl font-bold mb-4">Destaques</h3>
            <div class="flex flex-wrap gap-2">
              {passeio.tags.map(tag => (
                <span class="px-3 py-1 bg-primary-100 text-primary-700 rounded-full text-sm">
                  {tag}
                </span>
              ))}
            </div>
          </div>

          <!-- Galeria de Imagens -->
          <div class="mb-8">
            <h3 class="text-xl font-bold mb-4">Galeria</h3>
            <div class="grid grid-cols-2 lg:grid-cols-3 gap-4">
              {passeio.galeria.map((imagem, index) => (
                <div class="aspect-square overflow-hidden rounded-lg cursor-pointer hover:opacity-80 transition-opacity">
                  <img 
                    src={imagem} 
                    alt={`${passeio.titulo} - Imagem ${index + 1}`}
                    class="w-full h-full object-cover"
                    onclick={`openModal('${imagem}')`}
                  />
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Sidebar de Reserva -->
        <div class="lg:col-span-1">
          <div class="sticky top-32">
            <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-lg">
              <div class="text-center mb-6">
                <div class="text-gray-600 text-sm mb-1">A partir de:</div>
                <div class="text-3xl font-bold text-primary-600 mb-2">
                  R$ {passeio.preco.toFixed(2).replace('.', ',')}
                </div>
              </div>

              <!-- Informações do Passeio -->
              <div class="space-y-4 mb-6">
                <div class="flex justify-between">
                  <span class="text-gray-600">Duração:</span>
                  <span class="font-medium">{passeio.duracao}</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-gray-600">Horários:</span>
                  <span class="font-medium">{passeio.horarios.join(', ')}</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-gray-600">Categoria:</span>
                  <span class="font-medium">{passeio.categoria}</span>
                </div>
              </div>

              <!-- Botão de Compra pelo Site Oficial -->
              <a 
                href="https://ecommerce.spaceadventure.com.br/carrinho/ativarCupom?nrCupom=TOURLIVE&byUrl=true"
                target="_blank"
                class="w-full bg-primary-600 hover:bg-primary-700 text-white font-bold py-4 px-6 rounded-lg transition-colors flex items-center justify-center space-x-2 mb-4"
              >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                </svg>
                <span class="text-center">Compre com DESCONTO<br>pelo Site Oficial</span>
              </a>

              <a 
                href={whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-4 px-6 rounded-lg transition-colors flex items-center justify-center space-x-2"
              >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
                </svg>
                <span>Reservar via WhatsApp</span>
              </a>

              <div class="text-center mt-4">
                <p class="text-sm text-gray-600">Resposta rápida garantida!</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>