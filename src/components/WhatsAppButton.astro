---
// WhatsAppButton.astro - Botão flutuante do WhatsApp
---

<a 
  href="https://wa.me/5554993723094?text=Olá! Gostaria de mais informações sobre os passeios." 
  target="_blank" 
  rel="noopener noreferrer" 
  class="whatsapp-button fixed bottom-4 right-4 z-50 transition-all duration-300 hover:scale-110 block"
  aria-label="Fale conosco via WhatsApp"
>
  <img 
    src="/images/chamando.png" 
    alt="Mascote Partiu Viagem" 
    class="w-24 h-auto drop-shadow-xl"
  />
</a>

<style>
  .whatsapp-button {
    animation: pulse 2s infinite;
    filter: drop-shadow(0 4px 6px rgba(0, 0, 0, 0.3));
  }
  
  @keyframes pulse {
    0% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.1);
    }
    100% {
      transform: scale(1);
    }
  }
</style>