---
// HeroModerno.astro
---

<section id="hero-moderno" class="relative h-[85vh] md:h-[90vh] lg:h-screen w-full overflow-hidden bg-primary-900">
  <!-- Slides Container -->
  <div id="hero-slides" class="absolute inset-0 w-full h-full">
    <!-- Slide 1 -->
    <div class="hero-slide absolute inset-0 w-full h-full transition-opacity duration-1000 opacity-100 z-10" data-index="0">
      <div class="absolute inset-0 bg-cover bg-center bg-no-repeat transform transition-transform duration-[10000ms] ease-linear scale-100 hover:scale-110" style="background-image: url('/images/atacama-expedicao.jpg');"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-primary-900/90 via-primary-900/50 to-transparent"></div>
      
      <div class="relative z-20 h-full container mx-auto px-4 flex flex-col justify-center items-center text-center pt-16">
        <span class="inline-block py-1 px-3 rounded-full bg-secondary-500 text-primary-900 text-xs md:text-sm font-bold tracking-wider mb-4 animate-fade-in-up">EXPEDIÇÕES INTERNACIONAIS</span>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold text-white leading-tight mb-4 drop-shadow-lg animate-fade-in-up delay-100">
          Descubra a Magia do <br/>
          <span class="text-secondary-400">Deserto do Atacama</span>
        </h1>
        <p class="text-lg md:text-xl text-neutral-200 max-w-2xl mb-8 leading-relaxed drop-shadow-md animate-fade-in-up delay-200">
          Roteiros exclusivos e experiências inesquecíveis com a agência que mais entende de viagens.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto animate-fade-in-up delay-300">
          <a href="https://wa.me/5554993723094" target="_blank" class="px-8 py-4 bg-secondary-500 hover:bg-secondary-400 text-primary-900 font-bold rounded-lg shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-1 text-lg flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.017-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
            Falar no WhatsApp
          </a>
          <a href="#destinos" class="px-8 py-4 bg-transparent border-2 border-white text-white font-bold rounded-lg hover:bg-white/10 transition-all text-lg flex items-center justify-center">
            Ver Roteiros
          </a>
        </div>
      </div>
    </div>

    <!-- Slide 2 -->
    <div class="hero-slide absolute inset-0 w-full h-full transition-opacity duration-1000 opacity-0 z-0" data-index="1">
      <div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/images/cataratasquilombo.jpg');"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-primary-900/90 via-primary-900/50 to-transparent"></div>
      
      <div class="relative z-20 h-full container mx-auto px-4 flex flex-col justify-center items-center text-center pt-16">
        <span class="inline-block py-1 px-3 rounded-full bg-secondary-500 text-primary-900 text-xs md:text-sm font-bold tracking-wider mb-4">NATUREZA E PAZ</span>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold text-white leading-tight mb-4 drop-shadow-lg">
          Belezas Naturais em <br/>
          <span class="text-secondary-400">Cenários Únicos</span>
        </h1>
        <p class="text-lg md:text-xl text-neutral-200 max-w-2xl mb-8 leading-relaxed drop-shadow-md">
          Conheça cachoeiras e paisagens incríveis com todo conforto e segurança.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
          <a href="#destinos" class="px-8 py-4 bg-secondary-500 hover:bg-secondary-400 text-primary-900 font-bold rounded-lg shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-1 text-lg">
            Saiba Mais
          </a>
        </div>
      </div>
    </div>

    <!-- Slide 3 -->
    <div class="hero-slide absolute inset-0 w-full h-full transition-opacity duration-1000 opacity-0 z-0" data-index="2">
      <div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/images/cristoprotetor.jpg');"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-primary-900/90 via-primary-900/50 to-transparent"></div>
      
      <div class="relative z-20 h-full container mx-auto px-4 flex flex-col justify-center items-center text-center pt-16">
        <span class="inline-block py-1 px-3 rounded-full bg-secondary-500 text-primary-900 text-xs md:text-sm font-bold tracking-wider mb-4">ROTEIROS DE FÉ</span>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold text-white leading-tight mb-4 drop-shadow-lg">
          Visite o <br/>
          <span class="text-secondary-400">Cristo Protetor</span>
        </h1>
        <p class="text-lg md:text-xl text-neutral-200 max-w-2xl mb-8 leading-relaxed drop-shadow-md">
          Emoção e fé em Encantado - RS. Montamos o roteiro perfeito para você.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
          <a href="#contato" class="px-8 py-4 bg-secondary-500 hover:bg-secondary-400 text-primary-900 font-bold rounded-lg shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-1 text-lg">
            Solicitar Orçamento
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Navigation Dots -->
  <div class="absolute bottom-8 left-0 right-0 z-30 flex justify-center gap-3">
    <button class="slide-dot w-3 h-3 rounded-full bg-white/50 hover:bg-white transition-all duration-300 active-dot" aria-label="Slide 1" onclick="goToSlide(0)"></button>
    <button class="slide-dot w-3 h-3 rounded-full bg-white/50 hover:bg-white transition-all duration-300" aria-label="Slide 2" onclick="goToSlide(1)"></button>
    <button class="slide-dot w-3 h-3 rounded-full bg-white/50 hover:bg-white transition-all duration-300" aria-label="Slide 3" onclick="goToSlide(2)"></button>
  </div>

  <!-- Decorative Wave Bottom -->
  <div class="absolute bottom-0 left-0 right-0 z-20">
    <svg class="waves w-full h-[60px] md:h-[100px] min-h-[60px]" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 24 150 28" preserveAspectRatio="none" shape-rendering="auto">
      <defs>
        <path id="gentle-wave" d="M-160 44c30 0 58-18 88-18s 58 18 88 18 58-18 88-18 58 18 88 18 v44h-352z" />
      </defs>
      <g class="parallax">
        <use xlink:href="#gentle-wave" x="48" y="0" class="fill-neutral-50/70 dark:fill-neutral-900/70" />
        <use xlink:href="#gentle-wave" x="48" y="3" class="fill-neutral-50/50 dark:fill-neutral-900/50" />
        <use xlink:href="#gentle-wave" x="48" y="5" class="fill-neutral-50/30 dark:fill-neutral-900/30" />
        <use xlink:href="#gentle-wave" x="48" y="7" class="fill-neutral-50 dark:fill-neutral-900" />
      </g>
    </svg>
  </div>
</section>

<style>
  /* Wave Animation */
  .parallax > use {
    animation: move-forever 25s cubic-bezier(.55,.5,.45,.5) infinite;
  }
  .parallax > use:nth-child(1) {
    animation-delay: -2s;
    animation-duration: 7s;
  }
  .parallax > use:nth-child(2) {
    animation-delay: -3s;
    animation-duration: 10s;
  }
  .parallax > use:nth-child(3) {
    animation-delay: -4s;
    animation-duration: 13s;
  }
  .parallax > use:nth-child(4) {
    animation-delay: -5s;
    animation-duration: 20s;
  }
  @keyframes move-forever {
    0% {
     transform: translate3d(-90px,0,0);
    }
    100% { 
      transform: translate3d(85px,0,0);
    }
  }

  .active-dot {
    background-color: #eab308; /* secondary-500 */
    width: 2rem;
  }
  
  .animate-fade-in-up {
    animation: fadeInUp 0.8s ease-out forwards;
    opacity: 0;
    transform: translateY(20px);
  }
  
  .delay-100 { animation-delay: 0.1s; }
  .delay-200 { animation-delay: 0.2s; }
  .delay-300 { animation-delay: 0.3s; }
  
  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script is:inline>
  let currentSlide = 0;
  const slides = document.querySelectorAll('.hero-slide');
  const dots = document.querySelectorAll('.slide-dot');
  const totalSlides = slides.length;
  let slideInterval;

  function showSlide(index) {
    // Reset classes
    slides.forEach(slide => {
      slide.classList.remove('opacity-100', 'z-10');
      slide.classList.add('opacity-0', 'z-0');
    });
    
    dots.forEach(dot => {
      dot.classList.remove('active-dot');
    });

    // Set active slide
    slides[index].classList.remove('opacity-0', 'z-0');
    slides[index].classList.add('opacity-100', 'z-10');
    
    // Set active dot
    dots[index].classList.add('active-dot');
    
    // Re-trigger animations for text
    const animatedElements = slides[index].querySelectorAll('.animate-fade-in-up');
    animatedElements.forEach(el => {
      el.style.animation = 'none';
      el.offsetHeight; /* trigger reflow */
      el.style.animation = null; 
    });
  }

  function nextSlide() {
    currentSlide = (currentSlide + 1) % totalSlides;
    showSlide(currentSlide);
  }

  // Global function for dot clicks
  window.goToSlide = function(index) {
    currentSlide = index;
    showSlide(currentSlide);
    resetInterval();
  }

  function resetInterval() {
    clearInterval(slideInterval);
    slideInterval = setInterval(nextSlide, 5000);
  }

  // Initialize
  resetInterval();
</script>